# Exemple de configuration par variables d'environnement (compte unique).
# Copier en `.env` (gitignoré) puis renseigner le MOT DE PASSE.
#
# email-mcp ne charge PAS `.env` automatiquement. Deux façons de l'utiliser :
#   1) Node ≥ 20.6 / 22 : lancer avec le flag natif `--env-file=.env`
#        node --env-file=.env dist/main.js
#        npx tsx --env-file=.env scripts/draft-canet-signature.ts --logo /chemin/logo.png
#   2) Bloc `env` de la config MCP de votre client (Claude Desktop, Cursor…).
#
# Aucune de ces variables n'impose PostgreSQL : l'envoi/brouillon fonctionne
# sans base de données (le Postgres ne sert qu'au routage inter-comptes).

# --- Compte contact@pierrecanet.fr (OVH) ---
MCP_EMAIL_ACCOUNT_NAME=contact
MCP_EMAIL_ADDRESS=contact@pierrecanet.fr
MCP_EMAIL_FULL_NAME=Pierre CANET
MCP_EMAIL_PASSWORD=__A_RENSEIGNER__

# IMAP OVH (993 / SSL-TLS) — valeurs par défaut, listées pour mémoire.
MCP_EMAIL_IMAP_HOST=ssl0.ovh.net
MCP_EMAIL_IMAP_PORT=993
MCP_EMAIL_IMAP_TLS=true

# SMTP OVH (465 / SSL-TLS).
MCP_EMAIL_SMTP_HOST=ssl0.ovh.net
MCP_EMAIL_SMTP_PORT=465
MCP_EMAIL_SMTP_TLS=true
